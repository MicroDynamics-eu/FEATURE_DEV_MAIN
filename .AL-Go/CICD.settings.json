{
    "ConditionalSettings": [
        {
            "branches": [
                "dev"
            ],
            "settings": {
                 "runTests": true,
                 "testCodeunits": [
                    "UT_*",
                    "FT_*"
                 ]
            }
        },
      {
            "branches": [
                "release/*"
            ],
            "settings": {
                 "runTests": true,
                 "testCodeunits": [
                    "FT_*",
                    "E2E_*"
                 ]
            }
        },
      {
            "branches": [
                "main"
            ],
            "settings": {
                 "runTests": false
            }
        }
    ]
}