{
  "$schema": "https://raw.githubusercontent.com/microsoft/AL-Go-Actions/v9.0/.Modules/settings.schema.json",
  "country": "us",
  "appFolders": [],
  "testFolders": [],
  "bcptTestFolders": [],
  "environments": [
    "DEV",
    "PRD",
    "FAT"
  ],
  "DeployToDEV": {
    "EnvironmentName": "DEV",
    "ContinuousDeployment": true
  },
  "DeployToPRD": {
    "EnvironmentName": "PRD",
    "ContinuousDeployment": false
  },
  "DeployToFAT": {
    "EnvironmentName": "FAT",
    "ContinuousDeployment": false
  },
  "repoVersion": "2.0",
      "ConditionalSettings": [
        {
            "branches": [
                "dev"
            ],
            "settings": {
                 "runTests": true,
                 "testCodeunits": [
                    "UT_*",
                    "FT_*"
                 ],
                 "testCodeunitRange": "50401..50401"
            }
        },
      {
            "branches": [
                "release/*"
            ],
            "settings": {
                 "runTests": true,
                 "testCodeunits": [
                    "FT_*",
                    "E2E_*"
                 ]
            }
        },
      {
            "branches": [
                "main"
            ],
            "settings": {
                 "runTests": false
            }
        }
    ]
}
